PORT=4000
NODE_ENV=development
AUTOCAB_KEY=replace_with_your_autocab_subscription_key
ADMIN_PASSWORD=ChangeThisPasswordNow
ADMIN_SESSION_TTL_MS=28800000
PERMIT_CACHE_TTL_MS=600000
PERMIT_DETAIL_CONCURRENCY=6
BULK_UPDATE_CONCURRENCY=2
PING_TIMEOUT_MINUTES=10
STATUS_FILE=./status.json
PERMIT_AUDIT_FILE=./permit-audit.jsonl
H_CAPABILITY_IDS=14
GWR_PERMIT_FILE=./gwr-permits.json
GWR_PHOTO_DIR=./permit-photos

# Persistent application data (Coolify volume destination)
DATA_DIR=/app/data

# Evidence capture email (optional for local testing)
EVIDENCE_EMAIL=office@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=Plymouth Permit Evidence <office@example.com>

# SMTP2GO example (recommended test settings)
# SMTP_HOST=mail.smtp2go.com
# SMTP_PORT=2525
# SMTP_SECURE=false
# SMTP_USER=your_smtp2go_smtp_username
# SMTP_PASS=your_smtp2go_smtp_password
# SMTP_FROM=Plymouth Permit Evidence <verified-sender@yourdomain.co.uk>
